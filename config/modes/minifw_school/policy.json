{
  "_mode": "minifw_school",
  "_sector": "education",
  "_note": "SafeSearch enforcement, VPN/proxy blocking, content filtering. Thresholds pre-adjusted: block-10, monitor-10 from base.",
  "segments": {
    "default": {
      "block_threshold": 80,
      "monitor_threshold": 50
    },
    "staff": {
      "block_threshold": 80,
      "monitor_threshold": 50,
      "_note": "Staff network — standard school thresholds."
    },
    "student": {
      "block_threshold": 70,
      "monitor_threshold": 35,
      "_note": "Student network — stricter monitoring; SafeSearch enforced."
    },
    "guest": {
      "block_threshold": 60,
      "monitor_threshold": 30,
      "_note": "Visitor / guest WiFi — tightest thresholds."
    },
    "admin": {
      "block_threshold": 85,
      "monitor_threshold": 55,
      "_note": "Admin / management network — relaxed relative to student."
    }
  },
  "segment_subnets": {
    "staff":   ["192.168.1.0/24"],
    "student": ["10.10.0.0/16"],
    "guest":   ["192.168.100.0/24"],
    "admin":   ["10.0.0.0/24"]
  },
  "features": {
    "dns_weight":       40,
    "sni_weight":       35,
    "asn_weight":       15,
    "ip_denied_weight": 15,
    "burst_weight":     10,
    "mlp_weight":       30,
    "yara_weight":      35
  },
  "enforcement": {
    "ipset_name_v4":      "minifw_block_v4",
    "ip_timeout_seconds": 86400,
    "nft_table":          "inet",
    "nft_table_name":     "minifw",
    "nft_chain":          "forward"
  },
  "collectors": {
    "dnsmasq_log_path": "/opt/minifw_ai/logs/dnsmasq.log",
    "zeek_ssl_log_path": "/var/log/zeek/ssl.log",
    "use_zeek_sni": false
  },
  "burst": {
    "dns_queries_per_minute_monitor": 30,
    "dns_queries_per_minute_block":   50
  },
  "iomt_subnets": [],
  "safesearch_domains": ["google.com", "bing.com", "youtube.com", "duckduckgo.com"]
}
