{
  "policy_metadata": {
    "policy_id": "POL-EDU001",
    "version": "1.0.0",
    "sector": "education",
    "status": "active",
    "created_at": "2026-01-22T07:00:00Z",
    "created_by": "admin",
    "description": "Educational institution policy with strict student protection and content filtering",
    "compliance_tags": [
      "COPPA",
      "FERPA",
      "Child_Safety"
    ]
  },
  "sector_config": {
    "network_segments": {
      "student": {
        "subnets": [
          "10.0.10.0/24",
          "10.0.11.0/24"
        ],
        "block_threshold": 55,
        "monitor_threshold": 30,
        "description": "Student devices \u2014 strict filtering"
      },
      "staff": {
        "subnets": [
          "10.0.20.0/24"
        ],
        "block_threshold": 70,
        "monitor_threshold": 45,
        "description": "Staff devices \u2014 standard filtering"
      },
      "admin": {
        "subnets": [
          "10.0.1.0/24"
        ],
        "block_threshold": 85,
        "monitor_threshold": 60,
        "description": "Administration \u2014 relaxed filtering"
      }
    },
    "operating_hours": {
      "business_hours": {
        "start": "07:30",
        "end": "16:30"
      },
      "timezone": "Asia/Jakarta",
      "after_hours_strictness": "strict"
    },
    "risk_tolerance": "very_low",
    "critical_systems": [
      "10.0.1.1",
      "ldap.edu.local"
    ]
  },
  "ai_detection": {
    "feature_weights": {
      "dns_weight": 40,
      "sni_weight": 30,
      "asn_weight": 15,
      "burst_weight": 15
    },
    "threat_categories": {
      "gambling": {
        "enabled": true,
        "base_score": 80,
        "action": "block"
      },
      "malware": {
        "enabled": true,
        "base_score": 95,
        "action": "block"
      },
      "social_media": {
        "enabled": true,
        "action": "block",
        "allowed_hours": [
          {
            "start": "12:00",
            "end": "13:00"
          }
        ]
      }
    },
    "burst_detection": {
      "dns_queries_per_minute_monitor": 50,
      "dns_queries_per_minute_block": 100,
      "connection_rate_limit": 200
    }
  },
  "enforcement_rules": [
    {
      "rule_id": "RULE-EDU00001",
      "priority": 1,
      "name": "Block VPN and Proxy Services",
      "description": "Prevent students from bypassing content filters",
      "enabled": true,
      "conditions": {
        "threat_categories": [
          "api_abuse"
        ]
      },
      "action": {
        "type": "block",
        "duration_seconds": 3600
      }
    },
    {
      "rule_id": "RULE-EDU00002",
      "priority": 2,
      "name": "Block Piracy Sites",
      "description": "Block known torrent and warez sites",
      "enabled": true,
      "conditions": {},
      "action": {
        "type": "block",
        "duration_seconds": 86400
      }
    }
  ],
  "audit_config": {
    "retention_days": 365,
    "log_level": "info",
    "log_all_decisions": true,
    "export_format": [
      "json",
      "csv"
    ],
    "compliance_reporting": {
      "enabled": true,
      "report_frequency": "monthly",
      "recipients": [
        "admin@school.edu"
      ]
    }
  }
}
